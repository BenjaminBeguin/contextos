# Database (matches docker-compose.yml port mappings)
DATABASE_URL="postgresql://contextos:contextos@localhost:5455/contextos?schema=public"
REDIS_URL="redis://localhost:6380"

# API (port 3008)
API_PORT=3008
API_BASE_URL="http://localhost:3008"
JWT_SECRET="dev-secret-change-me"
# Comma-separated allowed origins: landing (3007) + product app (3009)
CORS_ORIGINS="http://localhost:3007,http://localhost:3009"

# Frontends
NEXT_PUBLIC_API_BASE_URL="http://localhost:3008"
NEXT_PUBLIC_APP_URL="http://localhost:3009"

# AI features (scan, extraction, docs, chat). Each WORKSPACE brings its own
# Anthropic key (BYOK, set in the app), so your global key isn't billed for
# everyone. The global key below is used only when ALLOW_GLOBAL_LLM=true (or
# outside production) — leave it off in prod so workspaces must BYOK.
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-sonnet-4-6"
# ALLOW_GLOBAL_LLM="false"

# GitHub OAuth (primary auth). Register an OAuth app at
# https://github.com/settings/developers with callback:
#   http://localhost:3008/auth/github/callback
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# Email/dev login is enabled automatically outside production. To force-disable:
# ALLOW_DEV_LOGIN="false"

# AI memory extraction (optional). Without a key, a heuristic fallback is used.
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-sonnet-4-6"

# Platform superadmins (comma-separated emails) for the /admin dashboard
# SUPERADMIN_EMAILS="you@company.com"
