{
  "name": "memmo",
  "version": "0.6.0",
  "description": "Long-term memory for AI coding agents — CLI + MCP server for Claude Code.",
  "license": "MIT",
  "author": "Benjamin Beguin",
  "homepage": "https://memmo.dev",
  "type": "module",
  "bin": {
    "memmo": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "ai",
    "memory",
    "context",
    "agents"
  ],
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "commander": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@memmo/shared": "workspace:*",
    "@types/node": "^22.10.5",
    "esbuild": "^0.21.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
