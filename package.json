{
  "name": "cortex-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Operational memory for AI coding agents",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "prisma migrate deploy && prisma generate && pnpm --parallel --filter ./apps/landing --filter ./apps/web --filter ./apps/api dev",
    "build": "pnpm -r build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "start:api": "prisma migrate deploy && prisma generate && tsx apps/api/src/server.ts",
    "cli": "pnpm --filter @mxbenjaminbeguin/cortex exec cortex",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:api": "node scripts/gen-api-docs.mjs"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma",
      "@prisma/engines",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  },
  "packageManager": "pnpm@10.30.1"
}
