generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email             String   @unique
  name              String?
  githubId          String?  @unique
  avatarUrl         String?
  githubAccessToken String?
  createdAt         DateTime @default(now())

  memberships Membership[]
  apiTokens   ApiToken[]
}

model Workspace {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  joinCode     String   @unique
  anthropicKey String? // encrypted; BYOK for this workspace's AI features
  autoApproveThreshold Float? // if set, proposed memories with confidence >= this are auto-approved
  autoRejectThreshold  Float? // if set, proposed memories with confidence < this are auto-rejected
  // Billing / plan (managed from the superadmin dashboard; Stripe fields reserved).
  plan             String    @default("free") // free | team | business | enterprise
  planSource       String    @default("none") // none | stripe | comp | manual
  planStatus       String    @default("active") // active | past_due | canceled
  planNote         String?
  planUpdatedAt    DateTime?
  stripeCustomerId String?
  // Bring-your-own-database (data residency, Enterprise). When connected, this
  // project's memory is stored in the customer's own Postgres. The URL is
  // encrypted; only status/metadata is kept in plaintext.
  externalDbUrl       String? // encrypted connection string
  externalDbStatus    String    @default("unconfigured") // unconfigured | connected | error
  externalDbError     String?
  externalDbCheckedAt DateTime?
  createdAt    DateTime @default(now())

  memberships    Membership[]
  repos          Repo[]
  auditLogs      AuditLog[]
  reviewerSkills ReviewerSkill[]
  billingEvents  BillingEvent[]
  apiTokens      ApiToken[]
}

/** Append-only log of billing/subscription activity — plan grants and changes
    now, real Stripe payments/invoices once billing is wired. Powers the admin
    payment log. */
model BillingEvent {
  id          String   @id @default(cuid())
  workspaceId String?
  type        String // plan.granted | plan.changed | plan.canceled | invoice.paid | payment.failed
  plan        String?
  amountCents Int?
  currency    String? // e.g. "usd"
  status      String? // paid | failed | comp
  note        String?
  actorEmail  String? // the admin who performed the action, when applicable
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([workspaceId, createdAt])
}

model Membership {
  id          String @id @default(cuid())
  userId      String
  workspaceId String
  role        String @default("owner")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Repo {
  id                   String   @id @default(cuid())
  workspaceId          String
  provider             String   @default("github")
  name                 String
  fullName             String
  defaultBranch        String?
  stack                String[] @default([])
  packageManager       String?
  notes                String?
  reviewerEnabled      Boolean  @default(false)
  reviewerInstructions String?
  createdAt            DateTime @default(now())

  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memories       Memory[]
  sessions       AgentSession[]
  docs           GeneratedDoc[]
  reviewerSkills RepoReviewerSkill[]
  reviews        PrReview[]
}

/** A named, reusable reviewer "skill" (instructions + optional path scope) owned by a
    workspace and attachable to any number of its repos. */
model ReviewerSkill {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  instructions String
  paths        String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repos     RepoReviewerSkill[]

  @@index([workspaceId])
}

/** Join table attaching reviewer skills to repos (many-to-many). */
model RepoReviewerSkill {
  repoId  String
  skillId String

  repo  Repo          @relation(fields: [repoId], references: [id], onDelete: Cascade)
  skill ReviewerSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([repoId, skillId])
  @@index([skillId])
}

model Memory {
  id         String    @id @default(cuid())
  repoId     String
  type       String
  title      String
  content    String
  paths      String[]  @default([])
  scope      String    @default("repo")
  confidence Float     @default(0.7)
  status     String    @default("proposed")
  source     String?
  usageCount Int       @default(0) // times served to an agent via MCP (impact signal)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime?

  repo           Repo              @relation(fields: [repoId], references: [id], onDelete: Cascade)
  evidence       MemoryEvidence[]
  reviewFindings PrReviewFinding[]

  @@index([repoId, status])
}

/** A persisted PR review generated by the memory-grounded reviewer. Kept so humans
    can give feedback on findings, which feeds back into memory confidence. */
model PrReview {
  id           String   @id @default(cuid())
  repoId       String
  prNumber     Int?
  prTitle      String
  source       String   @default("ci") // "ci" | "github" | "manual"
  summary      String
  findingCount Int      @default(0)
  createdAt    DateTime @default(now())

  repo     Repo              @relation(fields: [repoId], references: [id], onDelete: Cascade)
  findings PrReviewFinding[]

  @@index([repoId, createdAt])
}

/** One finding within a persisted review. `key` mirrors the GitHub dedup marker so
    feedback from either the web app or the PR can be attributed to the same finding. */
model PrReviewFinding {
  id          String    @id @default(cuid())
  reviewId    String
  key         String
  severity    String
  title       String
  detail      String
  path        String?
  line        Int?
  memoryId    String? // grounding memory, resolved from the referenced title
  memoryTitle String?
  feedback    String    @default("pending") // "pending" | "accepted" | "dismissed"
  feedbackAt  DateTime?
  createdAt   DateTime  @default(now())

  review PrReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  memory Memory?  @relation(fields: [memoryId], references: [id], onDelete: SetNull)

  @@index([reviewId])
  @@index([memoryId])
}

model MemoryEvidence {
  id        String   @id @default(cuid())
  memoryId  String
  kind      String
  content   String
  url       String?
  createdAt DateTime @default(now())

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
}

model AgentSession {
  id         String   @id @default(cuid())
  repoId     String
  agent      String
  task       String?
  summary    String?
  status     String   @default("completed")
  externalId String? // the agent's own session id (e.g. Claude Code session_id)
  errorCount Int      @default(0) // errors hit during the session (outcome signal)
  createdAt  DateTime @default(now())

  repo   Repo           @relation(fields: [repoId], references: [id], onDelete: Cascade)
  events SessionEvent[]
}

model SessionEvent {
  id        String   @id @default(cuid())
  sessionId String
  type      String
  payload   Json
  // Span fields (optional) — a session's events render as a timeline.
  name       String?
  durationMs Int?
  status     String? // ok | error | warning
  createdAt DateTime @default(now())

  session AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model GeneratedDoc {
  id        String   @id @default(cuid())
  repoId    String
  type      String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
}

model UsageEvent {
  id          String   @id @default(cuid())
  type        String
  workspaceId String?
  repoId      String?
  sessionId   String? // agent session id, when the event came from a hook in a session
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([workspaceId, createdAt])
}

model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())
}

model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  // When set, the token is bound to one project — the CLI/MCP can only reach
  // that workspace's repos with it. Null = account-wide (all your projects).
  workspaceId String?
  name        String    @default("cli")
  scope       String    @default("both") // "cli" | "mcp" | "both"
  hashedToken String    @unique
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}
